REACT_APP_BACKEND_URL=<https://your_url:your_react_app_port>
SERVER_PORT=<your_server_port>
REACT_APP_FIREBASE_API_KEY=<firebase_api_key>
REACT_APP_FIREBASE_AUTH_DOMAIN=<firebase_auth_domain>
REACT_APP_FIREBASE_PROJECT_ID=<firebase_project_id>
REACT_APP_FIREBASE_STORAGE_BUCKET=<firebase_storage_bucket>
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=<firebase_messaging_sender_id>
REACT_APP_FIREBASE_APP_ID=<firebase_app_id>
# If Firebase keys are not provided, app uses local email/password auth fallback automatically.
EXECUTION_PROVIDER=auto
ALLOW_LOCAL_EXECUTION_FALLBACK=true
ALLOWED_ORIGINS=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180

# Password recovery email delivery (required for real email inbox delivery)
APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Keep false unless debugging locally
AUTH_EXPOSE_RECOVERY_DEBUG=false

# Gmail quick setup
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_gmail@gmail.com
# SMTP_PASS=your_16_char_app_password
# SMTP_FROM=Sync Code <your_gmail@gmail.com>

# SendGrid SMTP
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=Sync Code <verified_sender@yourdomain.com>

# Resend SMTP
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your_resend_api_key
# SMTP_FROM=Sync Code <onboarding@resend.dev>